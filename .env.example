# -----------------------------------------------------------------------------
# ARCS — Advanced Research & Curation System
# Environment Configuration Template
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in your actual API keys.
# DO NOT commit your actual '.env' file to version control.

# Google Gemini API Keys for agent orchestration & key-rotation failover (https://aistudio.google.com/)
GOOGLE_API_KEY=your_primary_google_api_key
# GOOGLE_API_KEY_2=your_secondary_google_api_key
# GOOGLE_API_KEY_3=your_tertiary_google_api_key

# Tavily Search API Key for real-time web research (https://tavily.com/)
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Groq API Keys for high-RPM open-weights failover (https://console.groq.com/)
GROQ_API_KEY=gsk_your_primary_groq_key
# GROQ_API_KEY_2=gsk_your_secondary_groq_key

# OpenRouter API Keys for additional open-weights redundancy (https://openrouter.ai/)
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

